APP_NAME="ヴァルゼリアの冒険者 Local"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="local@example.test"
MAIL_FROM_NAME="${APP_NAME}"

CONTACT_MAIL_ADDRESS=local@example.test
CONTACT_MAIL_HOST=
CONTACT_MAIL_PORT=995
CONTACT_MAIL_USERNAME=
CONTACT_MAIL_PASSWORD=
CONTACT_MAIL_ENCRYPTION=ssl
CONTACT_MAIL_FETCH_LIMIT=30
CONTACT_MAIL_SMTP_HOST=
CONTACT_MAIL_SMTP_PORT=465
CONTACT_MAIL_SMTP_ENCRYPTION=ssl
CONTACT_MAIL_FROM_NAME="ヴァルゼリアの冒険者 Local"

STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

POCHI_GAME_PORTAL_ENABLED=false
POCHI_GAME_PORTAL_ENDPOINT=https://games-alchemist.com/api/portal/online-count/
POCHI_GAME_PORTAL_GAME_KEY=
POCHI_GAME_PORTAL_API_KEY=
POCHI_GAME_PORTAL_ONLINE_WINDOW_MINUTES=5

VITE_APP_NAME="${APP_NAME}"
