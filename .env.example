APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
PURCHASE_NOTIFICATION_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

CONTACT_MAIL_ADDRESS=info@valzeria.com
ADMIN_EMAIL=
CONTACT_MAIL_HOST=
CONTACT_MAIL_PORT=995
CONTACT_MAIL_USERNAME=
CONTACT_MAIL_PASSWORD=
CONTACT_MAIL_ENCRYPTION=ssl
CONTACT_MAIL_FETCH_LIMIT=30
CONTACT_MAIL_SMTP_HOST=
CONTACT_MAIL_SMTP_PORT=465
CONTACT_MAIL_SMTP_ENCRYPTION=ssl
CONTACT_MAIL_FROM_NAME="ヴァルゼリアの冒険者 運営"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PvE enemy -> player direct-damage formula. Set false only to temporarily use the legacy formula.
PVE_ENEMY_PERCENTAGE_DEFENSE_ENABLED=true
PVE_ENEMY_DEFENSE_COEFFICIENT=0.8

POCHI_GAME_PORTAL_ENABLED=false
POCHI_GAME_PORTAL_ENDPOINT=https://games-alchemist.com/api/portal/online-count/
POCHI_GAME_PORTAL_GAME_KEY=
POCHI_GAME_PORTAL_API_KEY=
POCHI_GAME_PORTAL_ONLINE_WINDOW_MINUTES=5
